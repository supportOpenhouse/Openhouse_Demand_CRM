# Copy to backend/.env for local dev. Never commit the real .env.
#
# IMPORTANT: wrap every value in SINGLE QUOTES so `source .env` doesn't choke
# on URL-safe characters like &, ?, =, *, (, ). Single quotes also disable
# shell expansion of $… inside the value.

# Neon pooler URL with ?sslmode=require (and sometimes &channel_binding=require)
DATABASE_URL='postgresql://USER:PASS@ep-xxx-pooler.ap-southeast-1.aws.neon.tech/oh_crm?sslmode=require&channel_binding=require'

# Google OAuth 2.0 Client (Web application) from console.cloud.google.com
GOOGLE_OAUTH_CLIENT_ID='xxxxxxxxxxxxxxxx.apps.googleusercontent.com'
GOOGLE_OAUTH_CLIENT_SECRET='GOCSPX-xxxxxxxxxxxxxxxxxxxx'
ALLOWED_EMAIL_DOMAIN='openhouse.in'

# 32+ char random. Generate: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET='replace-me-with-a-long-random-string'
SESSION_MAX_AGE_SECONDS='1209600'
SESSION_COOKIE_NAME='oh_crm_session'

# Where requests come from / where this API is reachable
FRONTEND_ORIGIN='https://openhouse-demand-crm.vercel.app'
API_BASE_URL='https://oh-demand-crm-api.onrender.com'

# Sheet sync — paste the service account JSON inline OR set the file path.
# Render: paste the inline form.  Local dev: file path is easier.
# If using inline: GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'
GOOGLE_SERVICE_ACCOUNT_JSON=''
GOOGLE_APPLICATION_CREDENTIALS_PATH=''

# Sheet IDs — only override if Akshit moves a sheet.
SHEET_ID_BROKERS='1bUkpfbceA7lLpMhRh2aoB-oGCwnzUiyD4sIclm25Z1k'
SHEET_ID_VISITS='17eEX021t97pGnJasMJ6v7ERE0jezKEC0S8teKepJRWQ'
SHEET_ID_INVENTORY='1-kxlCnXUv7absl4rpWeMoYIxSAHpWykyjpd9v_5df-o'
SHEET_ID_TEAM='18XoHGVorN5cMOIJSvfqS2cS6teGi-iq98xwdCp3ZBjk'

# Read snapshot size
SEED_VISITS_LIMIT='1500'

# Internal token Render Cron uses to call /admin/sync
INTERNAL_CRON_TOKEN='replace-me-with-another-long-random-string'

# 1 to run the sheet sync inside the web process (local dev). 0 for Render (use Cron Job).
RUN_SYNC_IN_PROCESS='0'
SYNC_INTERVAL_SECONDS='900'
