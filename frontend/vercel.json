{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://oh-demand-crm-api.onrender.com/api/:path*" },
    { "source": "/auth/:path*", "destination": "https://oh-demand-crm-api.onrender.com/auth/:path*" },
    { "source": "/health", "destination": "https://oh-demand-crm-api.onrender.com/health" },
    { "source": "/", "destination": "/crm.html" }
  ],
  "headers": [
    {
      "source": "/crm.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/brand/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/openhouse_logo.png",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ]
}
